    "validate:examples": "node bin/aof.js validate ../examples"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "js-yaml": "^4.1.0",
    "chalk": "^4.1.2"
