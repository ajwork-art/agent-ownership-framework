{
  "name": "aof-validate",
  "version": "2.0.0",
  "description": "Agent Ownership Framework (AOF) — deployment-time validation for machine-readable agent ownership contracts.",
  "keywords": ["ai-agents", "governance", "ownership", "contracts", "validation", "aof"],
  "license": "MIT",
  "author": "Anitha Jagadeesh",
  "homepage": "https://github.com/ajwork-art/agent-ownership-framework",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajwork-art/agent-ownership-framework.git"
  },
  "bin": {
    "aof": "bin/aof.js"
  },
  "main": "lib/validator.js",
  "files": [
    "bin/",
    "lib/",
    "aof/schema/agent-ownership-contract.schema.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
